---
/**
 * Giscus 评论组件
 * 评论通过 GitHub Discussions 存储，读者用 GitHub 账号登录即可发表。
 */
import { giscusConfig } from "../../config";

const { repo, repoId, category, categoryId, mapping, lang } = giscusConfig;
const enabled = !!(repo && repoId && category && categoryId);
---

{
  enabled && (
    <div class="mt-8 pt-6 border-t border-[var(--line-divider)]">
      <script
        src="https://giscus.app/client.js"
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
        data-mapping={mapping || "pathname"}
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="preferred_color_scheme"
        data-lang={lang || "zh-CN"}
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  )
}

{
  !enabled && (
    <div class="mt-8 pt-6 border-t border-[var(--line-divider)] text-center text-neutral-400 text-sm">
      💬 评论功能待配置。<br/>
      <span class="text-xs">（需在 GitHub 仓库启用 Discussions 并配置 Giscus）</span>
    </div>
  )
}
